{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true
  },
  "include": ["**/*.ts"],
  "exclude": [
      "node_modules", 
      "dist", 
      ".crispy-worktree", 
      ".crispy"
    ]
}